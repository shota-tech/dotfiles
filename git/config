[core]
	pager = delta

[interactive]
  diffFilter = delta --color-only

[ghq]
	root = ~/src

[alias]
	br = branch
	st = status
	ad = add .
	sw = switch
	swp = !git switch $(git branch | peco | tr -d ' *')
	cm = commit -m
	lg = log --oneline
	pll = pull
	psh = push -u origin HEAD
	stl = stash list
	sts = stash save -u -m
	stp = stash pop
	rss = reset --soft HEAD^

[include]
	path = ~/.config/delta/catppuccin.gitconfig

[delta]
  features = catppuccin-mocha
  dark = true
  line-numbers = true
  side-by-side = true

